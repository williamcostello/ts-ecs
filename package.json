{
  "name": "@williamcostello/ts-ecs",
  "version": "1.1.2",
  "description": "A TypeScript Entity Component System (ECS) implementation",
  "keywords": [
    "ecs",
    "entity-component-system",
    "typescript",
    "game",
    "gamedev"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamcostello/ts-ecs.git"
  },
  "homepage": "https://github.com/williamcostello/ts-ecs#readme",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "prepublishOnly": "yarn build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "3.0.7",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "~5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.7"
  }
}
